{
  "name": "viaticos-app-playwright",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright tests for the Portal de Viaticos de Benchmarking en IA.",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:demo": "set PLAYWRIGHT_DEMO=1&& playwright test --headed --workers=1",
    "install:browsers": "playwright install"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.30"
  }
}
